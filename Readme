4. How ot run setup and teardown
  a - there are 2 ways  globalconfig and project dependencies 
  add global files 

    globalSetup: require.resolve('./global/testglobal.setup.js'),
    globalTeardown: require.resolve('./global/testglobal.teardown.js'),
    write async function in these files and export them as globalSetup and globalTeardown

  b Project dependencies is the preferred one. 
  Add the below config and add dependency in other project
  {
      name: 'setup',
      testDir: "./global/", (********important*******)
      testMatch: 'global.setup.js',
      teardown:'teardown',

    },
    
    {
      name: 'teardown',
      testDir: "./global/", (********important*******)
      testMatch: 'global.teardown.js',

    },
    (********important*******)
import { te5st as setup } from '@playwright/test'; in setup.js 
import { test as teardown } from '@playwright/test'; in teardowndown.js
